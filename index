    width: 100px;
    height: 100px;
    border-radius: 50%;
    object-fit: cover;
    margin-bottom: 15px;
  }
  .card h2 {
    margin: 10px 0 5px;
    color: #333;
  }
  .card p {
    margin: 6px 0;
